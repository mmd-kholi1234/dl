/*remove the ads-sidebar-mobile */
@media (max-width: 768px) {
  .ads-sidebar-bottom {
    display: none;
  }
	#left-sidebar {
    display: none;
  }
}

/* Set width right sidebar & Add line in GeneratePress 

@media (min-width: 769px) {
    #primary {
        width: 70%;
    }
    #right-sidebar {
        width: 30%;
    }
	.inside-right-sidebar {
	border-left: 1px solid #D5D8DC;
	}
}

*/

/* Hide featured image post in GeneratePress */
.featured-image{ display:none; }

/* Sticky sidebar */
@media (min-width: 769px) {
.site-content {
  display: flex;
	}
	
.inside-right-sidebar {
  height: 100%;
	}
	
.inside-right-sidebar aside:last-child {
	position: -webkit-sticky;
	position: sticky;
	top: 20px; /*Adjust position */
  }
	
		.inside-left-sidebar {
  height: 100%;
	}
	
.inside-left-sidebar aside:last-child {
	position: -webkit-sticky;
	position: sticky;
	top: 20px; /*Adjust position */
  }
	
}

/* setting post wide */
.single-post .inside-article {
    padding: 15px;
}

/* setting feature image */
.post-image img {
    max-height: 150px;
    width: auto !important;
}

/* set breadcrumbs */
p#breadcrumbs {
    margin-bottom: 0;
    margin-top: 10px;
    font-size: 15px;
}

/* size header */
.inside-header {
    padding: 5px;
}

.single .entry-meta {
    font-size: 14px;
}

/* increase font menu */
.main-navigation a {
    font-size: 17px;
}

/* Chang Bulet-squal */
.entry-content ul li{
 list-style:square;
 }

/* Center search box side bar space */
.inside-header {
        padding: 0px;
    }
    .widget-area .widget {
        padding-top: 10px;
        padding-right: 40px;
        padding-bottom: 10px;
        padding-left: 40px;
    }
    .sidebar {
        margin-bottom: 0px;
    }
    .widget-title {
        margin-bottom: 20px;
    }
    p#breadcrumbs {
        margin-left: 20px;
        margin-right: 20px;
    }
    .site-header .header-image {
        margin-left: 15px;
    }
    .widget .search-form {
        display: flex;
        justify-content: center;
    }
    @media screen and (max-width: 480px) {
        .widget .search-form {
            padding-bottom: 30px;
        }
    }

/*----------31-3-2025----------*/

@media (min-width: 768px){
#content{
   /* border: 1px solid black */
}

#primary{
	position: relative; /* หรือ absolute แล้วกำหนดโครงสร้างให้เหมาะ */
    /*width: 71%;*/
	  width: 848.75px;
	flex-grow: 1;
    z-index: 99; /*content depth*/
    border-right: 1px solid #D5D8DC; /*content right-line*/
    border-left: 0px solid #D5D8DC; /*content left-line*/
}

#left-sidebar{
	position: relative; 
    /*width: 14%;*/
	  width: 167.33px;
	flex-shrink: 0;
    z-index: 99;
}

#right-sidebar{
    width: 363.92px;
    position: relative;
	  padding: 20px;
}

.inside-left-sidebar{
    height: 100%;
}
#custom_html-14{
	position: sticky;
  top: 20px;	
}

.site-header{
  position: static;   /*fixed header bar*/
}

.header-image{
    margin: 15px;
    padding-left: 20px;
}

.widget.inner-padding{
    padding-right: 0px;
    padding-left: 0px;
    padding-top: 20px;
    padding-bottom: 20px;
}
	
#main{
    margin: 0px;
}

p#breadcrumbs {
    margin-bottom: 0;
    margin-top: 0;
}
	}

/* Author Box */
.custom-author-box {
  display: flex;
  align-items: center;
  border-top: 1px solid #ccc;
  padding-top: 15px;
  margin-top: 40px;
  background-color: #f9f9f9;
  padding: 15px;
  border-radius: 6px;
}

.author-img {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  margin-right: 15px;
  object-fit: cover;
}

.author-info p {
  margin: 4px 0;
}

.author-info a {
  font-size: 0.9em;
  color: #0073aa;
  text-decoration: none;
}

.author-info a:hover {
  text-decoration: underline;
}

/* 13-7-2025 */

.ad-block {
  margin: 20px 0;
  text-align: center;
}

/* เพิ่มขนาดเฉพาะ .ad-desktop */
.ad-desktop {
  display: block;
  width: 728px;
  height: 90px;
  margin: 0 auto;
  background-color: #f5f5f5; /* ป้องกันพื้นที่ว่างดูขาดๆ */
}

/* ซ่อนบนมือถือ */
.ad-mobile {
  display: none;
}

@media (max-width: 768px) {
  .ad-desktop {
    display: none;
  }
  .ad-mobile {
    display: block;
  }
}


/* List Article */
.article-card {
  max-width: 600px;
  margin: 20px auto;
  padding: 16px;
  background-color: #fdfdfd;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0,0,0,0.1);
}

.article-title {
  font-size: 1.1em;
  color: 000;
  margin-bottom: 10px;
}

.article-image {
  width: 70%;
  height: auto;
  border-radius: 4px;
  margin-bottom: 12px;
}

.article-excerpt {
  font-size: 1em;
  color: #555;
  line-height: 1.6;
  margin-bottom: 10px;
}

.read-more {
  text-decoration: none;
  color: #007BFF;
  font-weight: bold;
}

.read-more:hover {
  text-decoration: underline;
}

hr {
  border: none;
  border-top: 1px solid #ccc;
  margin: 30px 0;
}

/* Latest post */

.latest-posts-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
  margin-top: 20px;
}

.latest-post-item {
  border: 1px solid #ddd;
  padding: 15px;
  background: #fff;
  border-radius: 5px;
  transition: box-shadow 0.2s;
}

.latest-post-item:hover {
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.latest-post-item .thumb img {
  max-width: 100%;
  height: auto;
  border-radius: 3px;
}

.latest-post-item .title {
  font-weight: bold;
  margin-top: 10px;
  font-size: 1.1em;
  color: #333;
}

.latest-post-item .excerpt {
  margin-top: 10px;
  color: #666;
  font-size: 0.95em;
  line-height: 1.4em;
}

/* Responsive สำหรับจอเล็ก */
@media (max-width: 768px) {
  .latest-posts-grid {
    grid-template-columns: 1fr;
  }
}

.read-more-wrap {
  margin-top: 10px;
}

.read-more-btn {
  display: inline-block;
  background-color: #0073aa;
  color: #fff;
  padding: 6px 12px;
  border-radius: 4px;
  font-size: 0.9em;
  text-decoration: none;
  transition: background-color 0.2s;
}

.read-more-btn:hover {
  background-color: #005f8a;
}

/* Custom TOC*/
.custom-toc {
  background: #f9f9f9;
  padding: 15px;
  border-left: 4px solid #4CAF50;
  margin-bottom: 20px;
}
.custom-toc ul {
  list-style-type: none;
  padding-left: 0;
}
.custom-toc li {
  margin-bottom: 8px;
}
.custom-toc a {
  text-decoration: none;
  color: #0066cc;
}

/* Lesson List */
.lesson-list {
  list-style-type: none;
  padding-left: 0;
}

.lesson-list ol {
  list-style-type: none;
  padding-left: 0;
}

.lesson-list li {
  margin-bottom: 10px;
}

.lesson-list li.active {
  font-weight: bold;
  background-color: #f1f8ff;
  border-left: 4px solid #0077cc;
  padding-left: 8px;
}

.lesson-list .pointer {
  margin-right: 6px;
  color: #0077cc;
}

/* add padding-botom image */
.wp-block-image {
	padding-bottom: 28.5px;
}

@media (max-width: 600px) {
  #nextpcb-banner {
    display: none;
  }
}		</style>
		</head>

